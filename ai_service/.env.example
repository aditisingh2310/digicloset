# ========================================
# Shopify Fashion Recommendation Engine
# Environment Configuration Template
# ========================================

# ========== MODEL CONFIGURATION ==========
# CLIP model from HuggingFace
CLIP_MODEL_NAME=openai/clip-vit-base-patch32

# Embedding dimension (CLIP outputs 512)
EMBEDDING_DIM=512

# ========== SERVICE CONFIGURATION ==========
# Host and port
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000

# Number of worker processes
NUM_WORKERS=4

# Enable auto-reload on code changes (development only)
RELOAD=false

# Log level: debug, info, warning, error
LOG_LEVEL=info

# ========== INDEX PATHS ==========
# Path to save/load FAISS index
INDEX_PATH=/data/recommendation_index/faiss.index

# Path to save/load index metadata
METADATA_PATH=/data/recommendation_index/metadata.json

# ========== RECOMMENDATION PARAMETERS ==========
# Weight of color similarity in outfit scoring
COLOR_WEIGHT=0.2

# Minimum similarity threshold for recommendations
SIMILARITY_THRESHOLD=0.3

# ========== CORS CONFIGURATION ==========
# Allowed origins for CORS (comma-separated)
# Use * for development, specific domains for production
CORS_ORIGINS=*

# ========== IMAGE PROCESSING ==========
# Image download timeout (seconds)
REQUEST_TIMEOUT=10

# Image size for preprocessing
IMAGE_SIZE=224,224

# ========== DATABASE (if using with metadata storage) ==========
DATABASE_URL=sqlite:///./recommendation.db

# ========== CACHING ==========
# Enable response caching
ENABLE_CACHE=true

# Cache TTL in seconds
CACHE_TTL=3600

# ========== MONITORING ==========
# Enable Prometheus metrics
ENABLE_METRICS=true

# Metrics port
METRICS_PORT=8001

# ========== GPU CONFIGURATION ==========
# Device: gpu or cpu (auto-detected if not specified)
# DEVICE=cuda

# CUDA device ID (for multi-GPU setups)
# CUDA_DEVICE_ID=0

# ========== PERFORMANCE ==========
# Maximum products in memory at once
MAX_BATCH_SIZE=256

# Request timeout in seconds
REQUEST_TIMEOUT=30

# ========== DEVELOPMENT ==========
# Include stack traces in error responses
DEBUG=false

# Verbose logging
VERBOSE=false
