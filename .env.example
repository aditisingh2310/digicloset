# ================================

# DIGICLOSET - PRODUCTION ENV FILE

# ================================

# ================================

# 🟢 SHOPIFY (REQUIRED)

# ================================

SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_API_SCOPES=read_products
SHOPIFY_APP_URL=https://your-app-domain.com
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret

SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_APPLICATION_URL=https://your-app-domain.com
SHOPIFY_EMBEDDED_APP_URL=https://your-app-domain.com/app
SHOPIFY_REDIRECT_URL=https://your-app-domain.com/auth/callback

# ================================

# 🔐 AUTH

# ================================

SESSION_SECRET=super_long_random_string_32_chars_min
JWT_SECRET=another_super_long_random_string

# ================================

# 🗄️ DATABASE (POSTGRES)

# ================================

DATABASE_URL=postgresql://postgres:password@localhost:5432/digicloset
POSTGRES_URL=postgresql://postgres:password@localhost:5432/digicloset

# ================================

# ⚡ REDIS

# ================================

REDIS_URL=redis://localhost:6379

# ================================

# 🤖 AI SERVICES

# ================================

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxx
EMBEDDING_API_KEY=sk-embedding-xxxxxxxxxxxx

AI_MODEL_NAME=clip-vit-large-patch14
AI_MODEL_VERSION=latest

# ================================

# ☁️ STORAGE (S3)

# ================================

AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
S3_BUCKET_NAME=digicloset-assets
CLOUD_STORAGE_URL=https://digicloset-assets.s3.amazonaws.com

# ================================

# 🌐 FRONTEND

# ================================

NEXT_PUBLIC_APP_URL=https://your-app-domain.com
NEXT_PUBLIC_API_URL=https://api.your-app-domain.com
NEXT_PUBLIC_SHOPIFY_API_KEY=your_shopify_api_key

# ================================

# 🔔 WEBHOOKS

# ================================

WEBHOOK_BASE_URL=https://your-app-domain.com

# ================================

# 💳 BILLING (SHOPIFY)

# ================================

SHOPIFY_BILLING_API_KEY=your_shopify_api_key
PLAN_BASIC_PRICE_ID=basic_plan_id
PLAN_PRO_PRICE_ID=pro_plan_id

# ================================

# 🔗 INTERNAL SERVICES

# ================================

AI_SERVICE_URL=http://localhost:8001
INFERENCE_SERVICE_URL=http://localhost:8002
QUEUE_SERVICE_URL=http://localhost:8003

# ================================

# 🧪 LOCAL DEV

# ================================

LOCAL_APP_URL=http://localhost:3000
LOCAL_API_URL=http://localhost:8000
LOCAL_FRONTEND_URL=http://localhost:5173

# ================================

# ⚠️ SYSTEM FLAGS

# ================================

NODE_ENV=development
ENV_VALIDATION_STRICT=true
