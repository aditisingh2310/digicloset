# ============================================
# DigiCloset Monorepo Configuration
# ============================================
# Copy this file to .env and update with your values

# ==== ENVIRONMENT ====
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or text

# ==== DATABASE ====
DATABASE_URL=postgresql://digicloset:digicloset_dev@localhost:5432/digicloset
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ==== REDIS ====
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ==== SHOPIFY INTEGRATION ====
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_API_VERSION=2024-01
SHOPIFY_SCOPES=write_products,read_customers,write_orders,read_orders

# ==== AI/ML SERVICES ====
CLIP_MODEL_NAME=openai/clip-vit-base-patch32
AI_INFERENCE_TIMEOUT=30
AI_CB_FAILURE_THRESHOLD=3
AI_CB_RESET_TIMEOUT=30

# ==== STORAGE (S3 or Local) ====
STORAGE_TYPE=local  # local or s3
LOCAL_STORAGE_PATH=/tmp/digicloset-storage

# S3 Configuration (if STORAGE_TYPE=s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ==== API CONFIGURATION ====
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:3001

# ==== BILLING ====
BILLING_ENABLED=true
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ==== SECURITY ====
SECRET_KEY=dev-secret-key-change-in-production-to-random-string
ALGORITHM=HS256
TOKEN_EXPIRATION_HOURS=24

# ==== EXTERNAL APIS ====
REPLICATE_API_TOKEN=
HUGGINGFACE_API_KEY=

# ==== QUEUE WORKER ====
CELERY_BROKER=redis://localhost:6379/1
CELERY_BACKEND=redis://localhost:6379/2
RQ_QUEUES=ai,default
