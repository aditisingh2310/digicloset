{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "lib": ["DOM", "ES2020"],
    "types": ["vitest/globals"]
  },
  "include": [
    "admin-ui/src/**/*",
    "components/**/*",
    "src/**/*",
    "tests/setup-vitest.js"
  ]
}
